# =============================================================================
# Oftalmología Si2 — PRODUCCIÓN (Azure VM)
# Archivo: .env  (en la raíz del repo, junto a docker-compose.yml)
# =============================================================================

COMPOSE_PROJECT_NAME=oftalmologia-si2

# ---- Dominio público ----
PUBLIC_DOMAIN=oftalmologia-si2.westus3.cloudapp.azure.com
AZURE_PUBLIC_FQDN=oftalmologia-si2.westus3.cloudapp.azure.com

# ---- PostgreSQL (servicio Docker "db"; NO cambiar POSTGRES_HOST) ----
POSTGRES_DB=oftalmologia_db
POSTGRES_USER=oftalmologia_user
POSTGRES_PASSWORD=CAMBIAR_password_seguro_postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django ----
# Generar: openssl rand -hex 32
DJANGO_SECRET_KEY=CAMBIAR_generar_con_openssl_rand_hex_32
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings
# Dominio + IP de la VM (por si entrás por IP)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,oftalmologia-si2.westus3.cloudapp.azure.com,20.150.149.206
# True cuando HTTPS ya funciona; False solo en bootstrap HTTP
DJANGO_SECURE_SSL_REDIRECT=True

CORS_ALLOWED_ORIGINS=https://oftalmologia-si2.westus3.cloudapp.azure.com
FRONTEND_URL=https://oftalmologia-si2.westus3.cloudapp.azure.com

JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7

# Pasarela mock interna (facturación CU21 — header X-Pasarela-Secret)
# Generar: openssl rand -hex 24
PASARELA_MOCK_SECRET=CAMBIAR_secreto_pasarela_mock

# ---- Bootstrap Docker (primera vez; luego podés poner RUN_SEEDERS=0) ----
DEMO_TENANT_SCHEMA=clinica_demo
DEMO_TENANT_SLUG=clinica-demo
DEMO_TENANT_NAME=Clínica Demo
DEMO_TENANT_EMAIL=demo@oftalmologia.local
DEMO_TENANT_DOMAIN=clinica-demo
RUN_MIGRATIONS=1
BOOTSTRAP_PUBLIC_SCHEMA=1
BOOTSTRAP_TENANTS=1
RUN_SEEDERS=1
RUN_COLLECTSTATIC=1

# ---- Next.js (se embebe en el BUILD — cambiar = rebuild frontend) ----
NEXT_PUBLIC_API_URL=https://oftalmologia-si2.westus3.cloudapp.azure.com/api
NEXT_PUBLIC_APP_NAME=OftalmoCRM

# ---- Email ----
# Demo/examen: Mailhog (correos en https://TU-DOMINIO:8025 o puerto 8025)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@oftalmologia.local
SITE_DISPLAY_NAME=Oftalmología Si2
HOST_PORT_MAILHOG_UI=8025
HOST_PORT_MAILHOG_SMTP=1025

# ---- Portainer (opcional; docker-compose.portainer.yml) ----
PORTAINER_BIND=127.0.0.1
PORTAINER_HOST_PORT=9000
PORTAINER_HTTPS_HOST_PORT=9443

# ---- IA Gemini (asistente virtual + reportes inteligentes) ----
# Clave: https://aistudio.google.com/apikey
GEMINI_API_KEY=CAMBIAR_tu_api_key_gemini
GEMINI_MODEL=gemini-2.5-flash

# ---- Stripe (planes SaaS / checkout) ----
# Dashboard: https://dashboard.stripe.com/test/apikeys (modo test)
# o https://dashboard.stripe.com/apikeys (modo live)
STRIPE_SECRET_KEY=sk_test_CAMBIAR_o_sk_live_CAMBIAR
STRIPE_WEBHOOK_SECRET=whsec_CAMBIAR_webhook_signing_secret
STRIPE_CURRENCY=usd
# Nota: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY está en .env.prod.example pero
# el checkout actual va por backend (checkout_url); no hace falta en frontend hoy.

# ---- JWT plataforma (superadmin SaaS) — opcional ----
PLATFORM_JWT_ACCESS_MINUTES=720

# ---- Firebase push (notificaciones móvil) — ruta al JSON, no la clave acá ----
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ---- Backup (opcional; defaults suelen alcanzar) ----
BACKUP_STORAGE_PATH=backups
BACKUP_TIMEOUT_SECONDS=600
BACKUP_MAX_SIZE_MB=500

# ---- Puertos host (prod: solo nginx expone 80/443) ----
HOST_PORT_POSTGRES=5432
HOST_PORT_BACKEND=8000
HOST_PORT_FRONTEND=3000
