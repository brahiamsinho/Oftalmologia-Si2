# =============================================================================
# REFERENCIA PRODUCCIÓN — NO LO USA DOCKER DIRECTAMENTE
# =============================================================================
# Este archivo es solo una guía. En la VM hacés:
#   cp .env.example .env
#   nano .env
# y copiás/peás los valores de acá (adaptando CAMBIAR_* y tu dominio/IP).
#
# Docker Compose SIEMPRE lee el archivo llamado:  .env
# =============================================================================

COMPOSE_PROJECT_NAME=oftalmologia-si2

# ---- Dominio (tu DNS Azure cloudapp) ----
# Reemplazá por tu FQDN si es distinto.
PUBLIC_DOMAIN=oftalmologia-si2.westus3.cloudapp.azure.com
AZURE_PUBLIC_FQDN=oftalmologia-si2.westus3.cloudapp.azure.com

# ---- PostgreSQL ----
# db = nombre del servicio en docker-compose (no cambiar en Docker).
POSTGRES_DB=oftalmologia_db
POSTGRES_USER=oftalmologia_user
POSTGRES_PASSWORD=CAMBIAR_password_seguro
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django ----
# Secret key: generá con  openssl rand -hex 32
DJANGO_SECRET_KEY=CAMBIAR_generar_con_openssl_rand_hex_32
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings
# Incluí dominio + IP pública de la VM (por si entrás por IP).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,oftalmologia-si2.westus3.cloudapp.azure.com,20.150.149.206
# False mientras uses HTTP sin certificado HTTPS.
DJANGO_SECURE_SSL_REDIRECT=False

# Orígenes permitidos para el navegador (con DEBUG=False es obligatorio).
CORS_ALLOWED_ORIGINS=http://oftalmologia-si2.westus3.cloudapp.azure.com,https://oftalmologia-si2.westus3.cloudapp.azure.com
# Links en emails, checkout, etc.
FRONTEND_URL=http://oftalmologia-si2.westus3.cloudapp.azure.com

JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7
PASARELA_MOCK_SECRET=CAMBIAR_secreto_pasarela

# ---- Bootstrap (primera vez en Docker; luego podés poner RUN_SEEDERS=0) ----
DEMO_TENANT_SCHEMA=clinica_demo
DEMO_TENANT_SLUG=clinica-demo
DEMO_TENANT_NAME=Clínica Demo
DEMO_TENANT_EMAIL=demo@oftalmologia.local
DEMO_TENANT_DOMAIN=clinica-demo
RUN_MIGRATIONS=1
BOOTSTRAP_PUBLIC_SCHEMA=1
BOOTSTRAP_TENANTS=1
RUN_SEEDERS=1
RUN_COLLECTSTATIC=1

# ---- Next.js ----
# IMPORTANTE: en build prod esta URL queda embebida. Usá http:// hasta tener HTTPS.
NEXT_PUBLIC_API_URL=http://oftalmologia-si2.westus3.cloudapp.azure.com/api
NEXT_PUBLIC_APP_NAME=OftalmoCRM

# ---- Email (Mailhog en la VM — UI en puerto 8025) ----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@oftalmologia.local
SITE_DISPLAY_NAME=Oftalmología Si2
HOST_PORT_MAILHOG_UI=8025
HOST_PORT_MAILHOG_SMTP=1025

# ---- IA Gemini (opcional; asistente y reportes inteligentes) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Platform admin (superadmin SaaS) ----
PLATFORM_ADMIN_EMAIL=platform@oftalmologia.local
PLATFORM_ADMIN_PASSWORD=CAMBIAR_password_platform

# ---- Stripe (opcional; planes de suscripción) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ---- Puertos en el host (prod suele exponer solo 80 vía nginx) ----
HOST_PORT_POSTGRES=5432
HOST_PORT_BACKEND=8000
HOST_PORT_FRONTEND=3000

# =============================================================================
# Cuando tengas HTTPS (certbot + docker-compose.https.yml), cambiá a https:// en:
#   NEXT_PUBLIC_API_URL, FRONTEND_URL, CORS_ALLOWED_ORIGINS
# y poné:  DJANGO_SECURE_SSL_REDIRECT=True
# Luego:  docker compose -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.https.yml up -d --build frontend backend
# Azure NSG: puerto 443 TCP abierto.
# =============================================================================
