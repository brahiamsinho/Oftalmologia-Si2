# ============================================
# Oftalmología Si2 — Variables de Entorno
# ============================================
# Copia este archivo a .env y configura tus valores
# cp .env.example .env

# ---- General ----
COMPOSE_PROJECT_NAME=oftalmologia-si2

# ---- PostgreSQL ----
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django Backend ----
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings
# Con DJANGO_DEBUG=True el backend añade '*' y acepta peticiones por IP LAN (móvil en Wi‑Fi).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7

# ---- Email (Mailhog en Docker dev | SMTP en producción) ----
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@oftalmologia.local
FRONTEND_URL=http://localhost:3000

# ---- Next.js Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=Oftalmología Si2

# ---- Flutter Mobile ----
API_BASE_URL=http://10.0.2.2:8000/api
