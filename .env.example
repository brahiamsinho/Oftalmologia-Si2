# ============================================
# OftalmoCRM — Variables de Entorno (plantilla)
# ============================================
# Copia este archivo a .env y configura tus valores:
#   cp .env.example .env
#
# Producción (Azure VM): mirá .env.prod.example como referencia de qué pegar en .env
#   nano .env

COMPOSE_PROJECT_NAME=oftalmologia-si2

# ---- PostgreSQL ----
POSTGRES_DB=oftalmologia_db
POSTGRES_USER=oftalmologia_user
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django Backend ----
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
# Solo producción sin HTTPS todavía: DJANGO_SECURE_SSL_REDIRECT=False

PUBLIC_DOMAIN=localhost
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7
PASARELA_MOCK_SECRET=dev-pasarela-secret

# Bootstrap (Docker entrypoint)
DEMO_TENANT_SCHEMA=clinica_demo
DEMO_TENANT_SLUG=clinica-demo
DEMO_TENANT_NAME=Clínica Demo
DEMO_TENANT_EMAIL=demo@oftalmologia.local
DEMO_TENANT_DOMAIN=clinica-demo

# ---- Next.js Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=OftalmoCRM

# ---- Flutter Mobile ----
API_BASE_URL=http://10.0.2.2:8000/api

# ---- Email (Mailhog en Docker) ----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@oftalmologia.local
HOST_PORT_MAILHOG_UI=8025
HOST_PORT_MAILHOG_SMTP=1025

# ---- IA / Reportes inteligentes (Gemini) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Puertos host (dev) ----
HOST_PORT_POSTGRES=5432
HOST_PORT_BACKEND=8000
HOST_PORT_FRONTEND=3000
