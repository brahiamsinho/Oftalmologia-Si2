# ============================================
# OftalmoCRM — Azure VM (producción)
# ============================================
# Generado con: ./scripts/azure/generate-env.sh oftalmologia-si2.westus3.cloudapp.azure.com
# Copiá a .env en la VM y completá secretos marcados con CAMBIAR.

COMPOSE_PROJECT_NAME=oftalmologia-si2

# ---- Dominio Azure (cloudapp.azure.com o dominio propio) ----
PUBLIC_DOMAIN=oftalmologia-si2.westus3.cloudapp.azure.com
AZURE_PUBLIC_FQDN=oftalmologia-si2.westus3.cloudapp.azure.com

# ---- PostgreSQL (solo red Docker; no exponer 5432 al internet) ----
POSTGRES_DB=oftalmologia
POSTGRES_USER=oftalmologia
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django ----
DJANGO_SECRET_KEY=CAMBIAR_GENERAR_CON_openssl_rand_hex_32
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,oftalmologia-si2.westus3.cloudapp.azure.com
# HTTP bootstrap (antes de certbot): False. Con HTTPS activo: True (default).
DJANGO_SECURE_SSL_REDIRECT=False

CORS_ALLOWED_ORIGINS=http://oftalmologia-si2.westus3.cloudapp.azure.com,https://oftalmologia-si2.westus3.cloudapp.azure.com
FRONTEND_URL=http://oftalmologia-si2.westus3.cloudapp.azure.com

JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7
PASARELA_MOCK_SECRET=CAMBIAR_SECRETO_PASARELA

# Bootstrap tenant demo (primera vez)
DEMO_TENANT_SCHEMA=clinica_demo
DEMO_TENANT_SLUG=clinica-demo
DEMO_TENANT_NAME=Clínica Demo
DEMO_TENANT_EMAIL=demo@oftalmologia.local
DEMO_TENANT_DOMAIN=clinica-demo
RUN_SEEDERS=1

# ---- Next.js (NEXT_PUBLIC_* se embebe en build — definir ANTES de docker compose build) ----
NEXT_PUBLIC_API_URL=http://oftalmologia-si2.westus3.cloudapp.azure.com/api
NEXT_PUBLIC_APP_NAME=OftalmoCRM

# ---- Email (Mailhog en prod para examen/demo; SMTP real cuando desactives mailhog) ----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@oftalmologia.local
HOST_PORT_MAILHOG_UI=8025

# ---- IA (opcional) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Puertos internos (prod overlay no publica 3000/8000/5432)
HOST_PORT_POSTGRES=5432
HOST_PORT_BACKEND=8000
HOST_PORT_FRONTEND=3000
