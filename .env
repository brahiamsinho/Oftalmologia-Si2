# ============================================
# Oftalmología Si2 — Variables de Entorno
# ============================================
# Copia este archivo a .env y configura tus valores
# cp .env.example .env
#
# En VM / nube: ajustá hosts y URLs públicas aquí (sin tocar código).
#
# --- Cambiar solo IP o dominio (mismo esquema/puertos) -----------------------
# Reemplazá TU_IP y, si aplica, el puerto del front (HOST_PORT_FRONTEND):
#   DJANGO_ALLOWED_HOSTS=... incluir TU_IP o el dominio
#   CORS_ALLOWED_ORIGINS=http://TU_IP:3000,...   (origen del navegador del panel)
#   FRONTEND_URL=http://TU_IP:3000
#   NEXT_PUBLIC_API_URL=http://TU_IP:8000/api
# Además, en mobile/.env: API_BASE_URL=http://TU_IP:8000/api
# Tras editar .env del monorepo: docker compose up -d --build (frontend recompila la URL pública).

# ---- General ----
COMPOSE_PROJECT_NAME=oftalmologia-si2

# ---- Puertos publicados en el host (Docker) ----
HOST_PORT_POSTGRES=5432
HOST_PORT_BACKEND=8000
HOST_PORT_FRONTEND=3000
HOST_PORT_MAILHOG_SMTP=1025
HOST_PORT_MAILHOG_UI=8025

# ---- PostgreSQL ----
POSTGRES_DB=oftalmologia_db
POSTGRES_USER=oftalmologia_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django Backend ----
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_SECRET_KEY
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings
# Obligatorio: hosts que Django acepta (sin http://), separados por coma.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,172.182.207.159
# Obligatorio si DJANGO_DEBUG=False: orígenes permitidos para CORS (con esquema y puerto).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://172.182.207.159:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7

# ---- Email (Mailhog en Docker dev | SMTP en producción) ----
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@oftalmologia.local
# Obligatorio: URL pública del panel web (enlaces en correos, etc.)
# Una sola URL base (la que uses para abrir el panel desde fuera de la VM).
FRONTEND_URL=http://localhost:3000,http://172.182.207.159:3000
#FRONTEND_URL=http://172.182.207.159:3000

# ---- Next.js Frontend ----
# Obligatorio para build y runtime: base de la API (sin barra final o con /api).
# Una sola URL: la del API tal como la ve el navegador (misma IP/puerto que HOST_PORT_BACKEND).
NEXT_PUBLIC_API_URL=http://localhost:8000/api,http://172.182.207.159:8000/api
#NEXT_PUBLIC_API_URL=http://172.182.207.159:8000/api
NEXT_PUBLIC_APP_NAME=Oftalmología Si2
# Hostname donde escucha `next dev` dentro del contenedor (0.0.0.0 = accesible desde fuera del contenedor)
NEXT_DEV_HOSTNAME=0.0.0.0

# ---- Flutter Mobile (solo archivo mobile/.env en el proyecto Flutter) ----
# API_BASE_URL=http://TU_IP_O_DOMINIO:8000/api
