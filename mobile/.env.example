# Mobile .env.example
# Base sin barra final. Django expone la API en /api/ (no /api/v1/).
#
# IMPORTANTE — 10.0.2.2 SOLO funciona en el EMULADOR Android, no en celular físico.
#
# | Dónde corrés la app        | API_BASE_URL típica                          |
# |----------------------------|-----------------------------------------------|
# | Emulador Android           | http://10.0.2.2:8000/api                      |
# | Celular físico (misma WiFi)| http://IP_DE_TU_PC:8000/api  (ipconfig IPv4)  |
# | Simulador iOS (Mac)        | http://127.0.0.1:8000/api                     |
#
# Probar en el navegador del celular: http://IP_DE_TU_PC:8000/api/health/
# Si no carga: firewall de Windows → permitir puerto 8000 (entrante) para Python/Docker.
API_BASE_URL=http://10.0.2.2:8000/api
APP_NAME=Oftalmología Si2
