# Mobile .env.example — copiar a mobile/.env
# La API Django usa el prefijo /api/ (rutas relativas tipo auth/login/ desde esta base).
#
# | Dónde corrés la app         | API_BASE_URL típica                          |
# |-----------------------------|-----------------------------------------------|
# | Emulador Android            | http://10.0.2.2:PUERTO/api                    |
# | Celular físico / VM / nube  | http://TU_IP_PUBLICA_O_DOMINIO:PUERTO/api   |
# | Simulador iOS (Mac)         | http://127.0.0.1:PUERTO/api                   |
#
# PUERTO = el que mapeaste en HOST_PORT_BACKEND (por defecto 8000).
# Sin barra final o con barra; la app normaliza a .../api/

API_BASE_URL=http://192.168.0.143:8000/api
APP_NAME=Oftalmología Si2

# Mailhog — ver correo de confirmación de registro (el envío lo hace el backend vía SMTP).
# Opción A: URL explícita de la UI web de Mailhog:
# MAILHOG_WEB_URL=http://10.0.2.2:8025
# Opción B: inferir desde API_BASE_URL (mismo host, puerto UI distinto — típico en celular físico):
# MAILHOG_INFER_FROM_API=true
# MAILHOG_UI_PORT=8025

# Texto bajo el título "Iniciar sesión" (opcional).
# LOGIN_SUBTITLE=Accedé con tu cuenta de la clínica.

# Enlaces legales (opcional). Si no los definís, la app avisa al tocar el link.
# LEGAL_TERMS_URL=https://ejemplo.com/terminos
# LEGAL_PRIVACY_URL=https://ejemplo.com/privacidad

# Teléfono de contacto (emergencias / agendar). Opcional; se usa en accesos rápidos y CTA del home.
# CLINIC_PHONE=+59171234567
